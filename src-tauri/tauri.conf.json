{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GDT Construction Planner",
  "version": "0.1.0",
  "identifier": "com.gdt.construction.planner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GDT Construction Planner",
        "width": 1100,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "copyright": "Copyright © Green Distillation Technologies",
    "publisher": "Green Distillation Technologies",
    "category": "Business",
    "shortDescription": "Construction estimate and quotation planner",
    "longDescription": "GDT Construction Planner — desktop suite for reactor-site estimates, line items, logistics, and client quotations. Project files use the .gctp format.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["gctp"],
        "name": "GDT Construction Estimate",
        "description": "GDT Construction Planner project",
        "mimeType": "application/json",
        "role": "Editor"
      }
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
